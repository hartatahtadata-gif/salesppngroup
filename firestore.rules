rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Reusable validation helpers
    function incoming() {
      return request.resource.data;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function isValidUser(data) {
      return data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 200
        && data.email is string && data.email.size() <= 200
        && data.role is string && (data.role == 'manager' || data.role == 'admin' || data.role == 'staff')
        && data.status is string && (data.status == 'active' || data.status == 'inactive')
        && (!('phone' in data) || (data.phone is string && data.phone.size() <= 50))
        && (!('avatarUrl' in data) || (data.avatarUrl is string && data.avatarUrl.size() <= 2048))
        && (!('password' in data) || (data.password is string && data.password.size() <= 128));
    }
    
    function isValidProduct(data) {
      return data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 256
        && data.stock is number
        && data.price is number
        && data.unit is string && data.unit.size() <= 50
        && data.expiryDate is string && data.expiryDate.size() <= 50;
    }
    
    function isValidTransaction(data) {
      return data.id is string && data.id.size() <= 128
        && data.staffId is string && data.staffId.size() <= 128
        && data.staffName is string && data.staffName.size() <= 200
        && data.adminId is string && data.adminId.size() <= 128
        && data.adminName is string && data.adminName.size() <= 200
        && data.type is string && (data.type == 'intake' || data.type == 'deposit' || data.type == 'return')
        && data.date is string && data.date.size() <= 50
        && (!('amount' in data) || data.amount is number)
        && (!('notes' in data) || (data.notes is string && data.notes.size() <= 1000))
        && (!('items' in data) || data.items is list);
    }

    function isValidApotikRecord(data) {
      return data.id is string && data.id.size() <= 128
        && data.namaApotik is string && data.namaApotik.size() <= 256
        && data.alamat is string && data.alamat.size() <= 500
        && data.kecamatan is string && data.kecamatan.size() <= 128
        && data.kabupaten is string && data.kabupaten.size() <= 128
        && data.productId is string && data.productId.size() <= 128
        && data.productName is string && data.productName.size() <= 256
        && data.jumlah is number
        && data.satuan is string && data.satuan.size() <= 50
        && data.nilai is number
        && data.total is number
        && data.staffId is string && data.staffId.size() <= 128
        && data.staffName is string && data.staffName.size() <= 200
        && data.date is string && data.date.size() <= 50;
    }

    match /users/{userId} {
      allow read: if true;
      allow create, update: if isValidId(userId) && isValidUser(incoming());
      allow delete: if isValidId(userId);
    }
    
    match /products/{productId} {
      allow read: if true;
      allow create, update: if isValidId(productId) && isValidProduct(incoming());
      allow delete: if isValidId(productId);
    }
    
    match /transactions/{transactionId} {
      allow read: if true;
      allow create, update: if isValidId(transactionId) && isValidTransaction(incoming());
      allow delete: if isValidId(transactionId);
    }

    match /apotik_records/{recordId} {
      allow read: if true;
      allow create, update: if isValidId(recordId) && isValidApotikRecord(incoming());
      allow delete: if isValidId(recordId);
    }

    match /test/{docId} {
      allow read: if true;
    }
  }
}
